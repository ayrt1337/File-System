generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  password   String
  avatarUrl  String?
  createdAt  DateTime  @default(now())
  lastUpdate DateTime?
  inactive   Boolean   @default(false)
  files      Files[]

  @@map("users")
}

model Files {
  id         String    @id @default(uuid())
  name       String
  format     String
  size       Int       @default(0)
  s3Key      String    @unique
  isPublic   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  lastUpdate DateTime?
  user       User      @relation(fields: [userId], references: [id])
  userId     String

  @@map("files")
}
