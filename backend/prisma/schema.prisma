generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User{
  id  Int @id @default(autoincrement())
  name String
  email String @unique
  password String

  @@map("users")
}

model Token{
  id Int @id @default(autoincrement())
  email String
  token String @unique
  password String?

  @@map("tokens")
}