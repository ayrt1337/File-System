generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User{
  id  Int @id @default(autoincrement())
  name String
  email String @unique
  password String
  cookie Cookie[]

  @@map("users")
}

model Cookie{
  id Int @id @default(autoincrement())
  cookie String @unique
  user User @relation(fields: [userId], references: [id])
  userId Int

  @@map("cookies") 
}