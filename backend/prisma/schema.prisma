generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User{
  id  Int @id @default(autoincrement())
  name String
  email String @unique
  password String
  createdAt DateTime
  lastUpdate DateTime
  inactive Boolean
  cookie Cookie[]
  files Files[]

  @@map("users")
}

model Cookie{
  id Int @id @default(autoincrement())
  cookie String @unique
  user User @relation(fields: [userId], references: [id])
  userId Int
  createdAt DateTime
  maxAge DateTime

  @@map("cookies") 
}

model Files{
  id Int @id @default(autoincrement())
  name String
  format String
  createdAt DateTime
  lastUpdate DateTime
  user User @relation(fields: [userId], references: [id])
  userId Int

  @@map("files")
}